{
  "buildCommand": "npm run build:client",
  "outputDirectory": "dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/((?!assets/|.*\\.(?:ico|png|jpg|jpeg|gif|svg|webp|css|js|json|woff2?|manifest\\.json)).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
